```gitignore
# Build artifacts
public/
resources/

# Dependencies
node_modules/

# Logs and temp files
*.log
*.tmp

# Environment
.env
.env.local
.env.*

# Editors
.vscode/
.idea/

# OS generated files
.DS_Store
Thumbs.db

# Coverage reports
coverage/
htmlcov/
*.coverage

# Python specific
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
*.egg-info/
.eggs/

# Hugo specific
.hugo_build.lock
```